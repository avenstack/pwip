{
  "listen": ":8080",
  "enable_subscription": true,
  "enable_speedtest": false,
  "config_reload_interval": "5s",
  "preferred_ip_csv": "preferred_ips.csv",
  "preferred_top_n": 20,
  "speedtest_interval": "1h",
  "speedtest_on_start": true,
  "speedtest": {
    "routines": 200,
    "ping_times": 4,
    "test_count": 10,
    "download_time_seconds": 10,
    "tcp_port": 443,
    "url": "https://cf.xiu2.xyz/url",
    "httping": false,
    "httping_code": 0,
    "httping_cfcolo": "",
    "max_delay_ms": 9999,
    "min_delay_ms": 0,
    "max_loss_rate": 1,
    "min_speed_mb": 0,
    "ip_file": "ip.txt",
    "ip_text": "",
    "output": "result.csv",
    "print_num": 0,
    "disable_download": false,
    "test_all_ip": false,
    "debug": false
  },
  "subscriptions": [
    {
      "name": "passwall",
      "path": "/sub/passwall",
      "token_template_files": {
        "your-token": "passwall_template.txt"
      },
      "content_type": "text/plain; charset=utf-8",
      "base64": true,
      "ip_placeholder": "{{IP}}",
      "ip_list_placeholder": "{{IP_LIST}}",
      "ip_list_separator": ",",
      "use_top_n": 1,
      "ip_strategy": "first"
    }
  ]
}
